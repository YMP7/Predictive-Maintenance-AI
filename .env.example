# AI Agent Configuration
MACHINE_ID=M001
MACHINE_TYPE=Lathe
MACHINE_LOCATION=Section A

# Simulation Configuration
SIMULATION_INTERVAL=1
SIMULATION_ENABLED=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# JWT Authentication (REQUIRED — the app will NOT start without this)
# Generate a secret with:  openssl rand -hex 32
JWT_SECRET_KEY=

# CORS Allowed Origins (comma-separated list of frontend URLs)
# If unset, defaults to http://localhost:3000 (dev only).
# In production, set this to your actual deployed frontend URL.
CORS_ORIGINS=http://localhost:3000

# Dashboard Configuration
DASHBOARD_PORT=3000
DASHBOARD_REFRESH_INTERVAL=2000

# Alert Configuration
ALERT_COOLDOWN=300
ALERT_LANGUAGES=en,hi,te,ta,mr

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
