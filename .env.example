# AI Agent Configuration
MACHINE_ID=M001
MACHINE_TYPE=Lathe
MACHINE_LOCATION=Section A

# Simulation Configuration
SIMULATION_INTERVAL=1
SIMULATION_ENABLED=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# JWT Authentication (REQUIRED — the app will NOT start without this)
# Generate a secret with:  openssl rand -hex 32
JWT_SECRET_KEY=

# CORS Allowed Origins (comma-separated list of frontend URLs)
# If unset, defaults to http://localhost:3000 (dev only).
# In production, set this to your actual deployed frontend URL.
CORS_ORIGINS=http://localhost:3000

# Dashboard Configuration
DASHBOARD_PORT=3000
DASHBOARD_REFRESH_INTERVAL=2000

# Alert Configuration
ALERT_COOLDOWN=300
ALERT_LANGUAGES=en,hi,te,ta,mr

# ── Notification Integration (Phase 5) ────────────────────────────
# Set NOTIFICATIONS_ENABLED=true to dispatch SMS/email/voice for Critical/High alerts.
# When false (default), alerts are logged to dashboard only — no external creds needed.
# IMPORTANT: If NOTIFICATIONS_ENABLED=true, ALL credentials below are REQUIRED.
# The server will refuse to start if any are missing (fail-loud pattern).
NOTIFICATIONS_ENABLED=false

# Twilio (SMS + Voice calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# SMTP (Email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_SSL=false
SMTP_USE_TLS=true
ALERT_EMAIL_TO=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# MQTT Ingestion Configuration (Backend Service Creds)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=backend_service
MQTT_PASSWORD=backend_secret
MQTT_TLS_ENABLED=false

# Note: Edge devices must use their per-device credentials for publishing.
# E.g., MQTT_USERNAME=device_M001, MQTT_PASSWORD=m001_secret

# TimescaleDB (REQUIRED — the app will NOT start without this)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://dtwin:CHANGE_ME@localhost:5432/digital_twin
TSDB_USER=dtwin
TSDB_PASSWORD=CHANGE_ME

# Application Environment (controls dev-only features like seed_dev.py)
APP_ENV=development
